---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Badge from '../../components/Badge.astro';
import Button from '../../components/Button.astro';
import PromptCard from '../../components/PromptCard.astro';
import { prompts, getPromptsByCategory } from '../../data/prompts';

export function getStaticPaths() {
  return prompts.map((prompt) => ({
    params: { id: prompt.id },
    props: { prompt },
  }));
}

const { prompt } = Astro.props;

// Get some related prompts from the same category
const relatedPrompts = getPromptsByCategory(prompt.category)
  .filter(p => p.id !== prompt.id)
  .slice(0, 3);
---

<Layout title={`${prompt.title} - AI Prompting Playbook`}>
  <Header />
  
  <main class="pt-32 pb-24 min-h-screen relative">
    <div class="absolute top-0 right-0 w-1/3 h-96 bg-accent-blue/10 rounded-full blur-[150px] -z-10"></div>
    
    <div class="container mx-auto px-4 max-w-4xl">
      <!-- Back navigation -->
      <a href={`/categories/${prompt.category}`} class="inline-flex items-center gap-2 text-text-secondary hover:text-white transition-colors mb-8 text-sm font-medium">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to Category
      </a>
      
      <!-- Prompt Header -->
      <div class="mb-10">
        <div class="flex flex-wrap gap-2 mb-6">
          {prompt.tags.map(tag => (
            <Badge variant="primary">{tag}</Badge>
          ))}
        </div>
        
        <h1 class="text-3xl md:text-5xl font-bold text-white mb-6 leading-tight">
          {prompt.title}
        </h1>
        
        <p class="text-xl text-text-secondary">
          {prompt.description}
        </p>
      </div>
      
      <!-- Prompt Content Area -->
      <div class="bg-bg-secondary border border-white/10 rounded-2xl overflow-hidden mb-16 shadow-2xl relative">
        <div class="bg-bg-tertiary px-6 py-4 border-b border-white/10 flex justify-between items-center">
          <div class="flex gap-2">
            <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
            <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
          </div>
          <Button 
            class="copy-btn !py-1.5 !px-4 text-sm" 
            variant="outline" 
            data-content={prompt.content}
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
            <span class="btn-text">Copy</span>
          </Button>
        </div>
        
        <div class="p-6 md:p-8">
          <pre class="font-mono text-text-primary whitespace-pre-wrap leading-relaxed text-sm md:text-base"><code>{prompt.content}</code></pre>
        </div>
      </div>
      
      <!-- Related Prompts -->
      {relatedPrompts.length > 0 && (
        <div class="pt-12 border-t border-white/10">
          <h2 class="text-2xl font-bold text-white mb-8">You might also like</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {relatedPrompts.map(p => (
              <PromptCard prompt={p} />
            ))}
          </div>
        </div>
      )}
    </div>
  </main>
  
  <Footer />
</Layout>

<script>
  // Script is already handled globally in PromptCard.astro, but we can re-initialize or add specific logic here if needed.
  // The copy-btn class hook will be picked up by the script in PromptCard if we extract it, 
  // but since we want this page to work independently, let's add a small script just for this button.
  
  const copyBtns = document.querySelectorAll('.copy-btn');
  
  copyBtns.forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const button = e.currentTarget as HTMLButtonElement;
      const content = button.getAttribute('data-content');
      const textSpan = button.querySelector('.btn-text');
      const originalText = textSpan?.textContent || 'Copy';
      
      if (content) {
        try {
          await navigator.clipboard.writeText(content);
          if (textSpan) textSpan.textContent = 'Copied!';
          button.classList.add('bg-green-500/20', 'border-green-500/50', 'text-green-400');
          
          setTimeout(() => {
            if (textSpan) textSpan.textContent = originalText;
            button.classList.remove('bg-green-500/20', 'border-green-500/50', 'text-green-400');
          }, 2000);
        } catch (err) {
          console.error('Failed to copy', err);
        }
      }
    });
  });
</script>
