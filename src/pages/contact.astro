---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
---

<Layout title="Contact Us - AI Prompting Playbook">
  <Header />
  
  <main class="pt-32 pb-24 min-h-screen relative">
    <div class="absolute top-0 left-0 w-full h-[500px] bg-gradient-to-b from-bg-secondary to-transparent -z-10"></div>
    
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">
          Get in <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent-blue to-accent-purple">Touch</span>
        </h1>
        <p class="text-lg text-text-secondary max-w-2xl mx-auto">
          Have a specific prompt request, feedback, or want to explore an enterprise partnership? We'd love to hear from you.
        </p>
      </div>
      
      <div class="flex flex-col md:flex-row gap-12">
        <div class="flex-1">
          <div class="bg-bg-secondary border border-white/10 rounded-3xl p-8 shadow-2xl relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-accent-blue/10 rounded-full blur-[50px] -z-10"></div>
            
            <form class="space-y-6">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div class="space-y-2">
                  <label for="firstName" class="text-sm font-medium text-text-secondary">First Name</label>
                  <input type="text" id="firstName" class="w-full bg-bg-tertiary border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-accent-purple focus:ring-1 focus:ring-accent-purple transition-colors" placeholder="John" />
                </div>
                <div class="space-y-2">
                  <label for="lastName" class="text-sm font-medium text-text-secondary">Last Name</label>
                  <input type="text" id="lastName" class="w-full bg-bg-tertiary border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-accent-purple focus:ring-1 focus:ring-accent-purple transition-colors" placeholder="Doe" />
                </div>
              </div>
              
              <div class="space-y-2">
                <label for="email" class="text-sm font-medium text-text-secondary">Email Address</label>
                <input type="email" id="email" class="w-full bg-bg-tertiary border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-accent-purple focus:ring-1 focus:ring-accent-purple transition-colors" placeholder="john@example.com" />
              </div>
              
              <div class="space-y-2">
                <label for="subject" class="text-sm font-medium text-text-secondary">Subject</label>
                <select id="subject" class="w-full bg-bg-tertiary border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-accent-purple focus:ring-1 focus:ring-accent-purple transition-colors appearance-none">
                  <option value="general">General Inquiry</option>
                  <option value="support">Technical Support</option>
                  <option value="partnership">Enterprise Partnership</option>
                  <option value="feedback">Feedback / Suggestion</option>
                </select>
              </div>
              
              <div class="space-y-2">
                <label for="message" class="text-sm font-medium text-text-secondary">Message</label>
                <textarea id="message" rows="5" class="w-full bg-bg-tertiary border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-accent-purple focus:ring-1 focus:ring-accent-purple transition-colors resize-none" placeholder="How can we help you?"></textarea>
              </div>
              
              <Button type="button" variant="primary" class="w-full py-4 text-lg">
                Send Message
              </Button>
            </form>
          </div>
        </div>
        
        <div class="w-full md:w-80 space-y-8">
          <div>
            <h3 class="text-xl font-bold text-white mb-4">Contact Information</h3>
            <p class="text-text-secondary mb-6 text-sm">
              We aim to respond to all inquiries within 24-48 business hours.
            </p>
            
            <div class="space-y-4">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-full bg-bg-tertiary border border-white/10 flex items-center justify-center shrink-0 text-accent-blue">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <h4 class="text-white font-medium mb-1">Email</h4>
                  <a href="mailto:hello@promptplaybook.com" class="text-text-secondary hover:text-accent-blue transition-colors text-sm">hello@promptplaybook.com</a>
                </div>
              </div>
              
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-full bg-bg-tertiary border border-white/10 flex items-center justify-center shrink-0 text-accent-purple">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div>
                  <h4 class="text-white font-medium mb-1">HQ Location</h4>
                  <p class="text-text-secondary text-sm">San Francisco, CA<br />Remote Worldwide</p>
                </div>
              </div>
            </div>
          </div>
          
          <div class="bg-gradient-to-br from-accent-blue/10 to-accent-purple/10 border border-white/10 rounded-2xl p-6">
            <h3 class="text-white font-bold mb-2">Looking for custom prompts?</h3>
            <p class="text-text-secondary text-sm mb-4">We offer enterprise consulting to build internal prompt libraries tailored to your company's workflows.</p>
            <a href="#" class="text-accent-blue font-medium hover:text-white transition-colors text-sm flex items-center gap-1">
              Learn more about enterprise
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>
  
  <Footer />
</Layout>
