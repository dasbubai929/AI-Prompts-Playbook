---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Badge from '../../components/Badge.astro';

// Use import.meta.glob to fetch all markdown files in the blog directory
const posts: any[] = Object.values(import.meta.glob('./*.md', { eager: true }));
const sortedPosts = posts.sort((a, b) => new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf());
---

<Layout title="Blog - AI Prompting Playbook">
  <Header />
  
  <main class="pt-32 pb-24 min-h-screen relative">
    <div class="absolute top-0 right-1/4 w-1/3 h-96 bg-accent-purple/10 rounded-full blur-[150px] -z-10"></div>
    
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">
          The <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent-blue to-accent-purple">Prompting</span> Blog
        </h1>
        <p class="text-lg text-text-secondary max-w-2xl mx-auto">
          Learn how to engineer better prompts, automate workflows, and get the most out of AI.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {sortedPosts.map((post) => (
          <a href={post.url} class="group bg-bg-secondary border border-white/10 rounded-2xl p-6 hover:border-accent-blue/50 hover:shadow-glow transition-all duration-300 flex flex-col h-full">
            <div class="flex gap-2 mb-4">
              {post.frontmatter.tags?.slice(0, 2).map((tag: string) => (
                <Badge>{tag}</Badge>
              ))}
            </div>
            
            <h2 class="text-2xl font-bold text-white mb-3 group-hover:text-accent-blue transition-colors">
              {post.frontmatter.title}
            </h2>
            
            <p class="text-text-secondary mb-6 flex-grow">
              {post.frontmatter.excerpt}
            </p>
            
            <div class="flex justify-between items-center text-sm text-text-muted mt-auto pt-4 border-t border-white/10">
              <span>{post.frontmatter.date}</span>
              <span class="text-accent-blue font-medium group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">
                Read Article
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>
  
  <Footer />
</Layout>
