---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PromptCard from '../../components/PromptCard.astro';
import { categories, getPromptsByCategory, prompts } from '../../data/prompts';

export function getStaticPaths() {
  const allCategoriesPath = {
    params: { category: 'all' },
    props: { 
      name: 'All Prompts', 
      prompts: prompts,
      currentCategory: 'all'
    }
  };
  
  const categoryPaths = categories.map((cat) => {
    return {
      params: { category: cat.id },
      props: { 
        name: cat.name, 
        prompts: getPromptsByCategory(cat.id),
        currentCategory: cat.id
      }
    };
  });
  
  return [allCategoriesPath, ...categoryPaths];
}

const { category } = Astro.params;
const { name, prompts: categoryPrompts, currentCategory } = Astro.props;
---

<Layout title={`${name} AI Prompts - AI Prompting Playbook`}>
  <Header />
  
  <main class="pt-32 pb-24 min-h-screen relative">
    <!-- Background effects -->
    <div class="absolute top-0 left-0 w-full h-96 bg-gradient-to-b from-bg-secondary to-transparent -z-10"></div>
    
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">
          AI Prompts for <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent-blue to-accent-purple">{name}</span>
        </h1>
        <p class="text-lg text-text-secondary max-w-2xl mx-auto">
          Explore our curated collection of high-quality prompts designed specifically for {name.toLowerCase()}.
        </p>
      </div>
      
      <!-- Category Navigation -->
      <div class="flex flex-wrap justify-center gap-3 mb-12 border-b border-white/10 pb-8">
        <a 
          href="/categories/all"
          class={`px-5 py-2 rounded-full font-medium transition-all ${
            currentCategory === 'all' 
              ? 'bg-accent-blue/20 text-accent-blue border border-accent-blue/30' 
              : 'bg-bg-tertiary text-text-secondary border border-white/10 hover:text-white hover:border-white/30'
          }`}
        >
          All Prompts
        </a>
        {categories.map(cat => (
          <a 
            href={`/categories/${cat.id}`}
            class={`px-5 py-2 rounded-full font-medium transition-all ${
              currentCategory === cat.id 
                ? 'bg-accent-blue/20 text-accent-blue border border-accent-blue/30' 
                : 'bg-bg-tertiary text-text-secondary border border-white/10 hover:text-white hover:border-white/30'
            }`}
          >
            {cat.name}
          </a>
        ))}
      </div>
      
      <!-- Prompts Grid -->
      {categoryPrompts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {categoryPrompts.map(prompt => (
            <PromptCard prompt={prompt} />
          ))}
        </div>
      ) : (
        <div class="text-center py-20 bg-bg-secondary/50 rounded-2xl border border-white/5">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mx-auto text-text-muted mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
          <h3 class="text-xl font-semibold text-white mb-2">No prompts found</h3>
          <p class="text-text-secondary">We're still adding prompts to this category. Check back soon!</p>
        </div>
      )}
    </div>
  </main>
  
  <Footer />
</Layout>
