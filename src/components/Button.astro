---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'outline';
  class?: string;
  type?: 'button' | 'submit' | 'reset';
  id?: string;
}

const { href, variant = 'primary', class: className = '', type = 'button', id } = Astro.props;

const baseStyles = "inline-flex items-center justify-center gap-2 px-6 py-2.5 rounded-lg font-medium transition-all duration-300 transform active:scale-95";

const variants = {
  primary: "bg-gradient-to-r from-accent-blue to-accent-purple text-white shadow-lg shadow-accent-purple/25 hover:shadow-accent-blue/40 hover:-translate-y-0.5",
  secondary: "bg-bg-tertiary text-white hover:bg-bg-tertiary/80 border border-white/10",
  outline: "bg-transparent border border-white/20 text-white hover:border-white/40 hover:bg-white/5",
};

const classes = `${baseStyles} ${variants[variant]} ${className}`;
---

{href ? (
  <a href={href} class={classes} id={id}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} id={id}>
    <slot />
  </button>
)}
