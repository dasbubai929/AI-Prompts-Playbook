---
import type { Prompt } from '../data/prompts';
import Badge from './Badge.astro';
import Button from './Button.astro';

interface Props {
  prompt: Prompt;
}

const { prompt } = Astro.props;
---

<div class="group bg-bg-secondary/50 backdrop-blur-sm border border-white/10 rounded-xl p-6 transition-all duration-300 hover:shadow-glow hover:border-accent-purple/50 flex flex-col h-full relative overflow-hidden">
  <div class="absolute top-0 right-0 p-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
    <a href={`/prompt/${prompt.id}`} class="text-text-muted hover:text-white" title="View Details">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
        <path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z" />
        <path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z" />
      </svg>
    </a>
  </div>

  <div class="mb-4">
    <h3 class="text-lg font-semibold text-white mb-2 leading-tight group-hover:text-accent-blue transition-colors pr-8">
      {prompt.title}
    </h3>
    <p class="text-sm text-text-secondary line-clamp-2">
      {prompt.description}
    </p>
  </div>
  
  <div class="flex flex-wrap gap-2 mb-6 mt-auto">
    {prompt.tags.slice(0, 3).map(tag => (
      <Badge>{tag}</Badge>
    ))}
    {prompt.tags.length > 3 && (
      <Badge>+{prompt.tags.length - 3}</Badge>
    )}
  </div>
  
  <div class="pt-4 border-t border-white/10 mt-auto">
    <div class="bg-bg-primary/80 rounded-md p-3 mb-4 h-24 overflow-hidden relative">
      <p class="text-xs font-mono text-text-muted line-clamp-4 leading-relaxed">
        {prompt.content}
      </p>
      <div class="absolute bottom-0 left-0 right-0 h-12 bg-gradient-to-t from-bg-primary/90 to-transparent"></div>
    </div>
    
    <div class="flex gap-3">
      <Button 
        class="w-full copy-btn group/btn" 
        variant="primary" 
        data-content={prompt.content}
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
        </svg>
        <span class="btn-text">Copy Prompt</span>
      </Button>
    </div>
  </div>
</div>

<script>
  // Setup copy buttons globally
  const copyButtons = document.querySelectorAll('.copy-btn');
  
  copyButtons.forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const button = e.currentTarget as HTMLButtonElement;
      const content = button.getAttribute('data-content');
      const textSpan = button.querySelector('.btn-text');
      const originalText = textSpan?.textContent || 'Copy Prompt';
      
      if (content) {
        try {
          await navigator.clipboard.writeText(content);
          if (textSpan) textSpan.textContent = 'Copied!';
          button.classList.add('from-green-500', 'to-emerald-500');
          button.classList.remove('from-accent-blue', 'to-accent-purple');
          
          setTimeout(() => {
            if (textSpan) textSpan.textContent = originalText;
            button.classList.remove('from-green-500', 'to-emerald-500');
            button.classList.add('from-accent-blue', 'to-accent-purple');
          }, 2000);
        } catch (err) {
          console.error('Failed to copy', err);
        }
      }
    });
  });
</script>
