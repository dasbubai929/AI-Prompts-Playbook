---
import { prompts } from '../data/prompts';
import PromptCard from './PromptCard.astro';

const trending = prompts.filter((p) => p.trending).slice(0, 5);
---

<section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
  <div class="mb-10 text-center">
    <span class="inline-block rounded-full bg-violet/20 px-3 py-1 text-xs font-medium text-violet-soft font-mono">Featured</span>
    <h2 class="mt-3 text-2xl font-semibold tracking-tight sm:text-3xl">Trending Prompts</h2>
    <p class="mt-2 text-sm text-body">Most popular prompts this week</p>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {trending.map((prompt) => (
      <PromptCard prompt={prompt} featured={true} />
    ))}
  </div>
</section>
