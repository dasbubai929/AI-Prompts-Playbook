---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Badge from '../components/Badge.astro';
import PromptCard from '../components/PromptCard.astro';
import { getTrendingPrompts, categories } from '../data/prompts';

const { frontmatter } = Astro.props;
const trendingPrompts = getTrendingPrompts().slice(0, 2);
---

<Layout title={`${frontmatter.title} - AI Prompting Playbook`}>
  <Header />
  
  <main class="pt-32 pb-24 min-h-screen">
    <div class="container mx-auto px-4 max-w-7xl">
      <div class="flex flex-col lg:flex-row gap-12">
        
        <!-- Blog Content -->
        <article class="flex-1 max-w-4xl">
          <a href="/blog" class="inline-flex items-center gap-2 text-text-secondary hover:text-white transition-colors mb-8 text-sm font-medium">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back to Blog
          </a>
          
          <header class="mb-10">
            <div class="flex gap-2 mb-4">
              {frontmatter.tags?.map((tag: string) => (
                <Badge variant="primary">{tag}</Badge>
              ))}
            </div>
            <h1 class="text-4xl md:text-5xl font-bold text-white mb-6 leading-tight">
              {frontmatter.title}
            </h1>
            <div class="text-text-muted flex items-center gap-4 text-sm">
              <span>{frontmatter.date}</span>
              <span>•</span>
              <span>{frontmatter.author}</span>
            </div>
          </header>
          
          <div class="prose prose-invert prose-lg max-w-none prose-headings:text-white prose-a:text-accent-blue hover:prose-a:text-accent-purple prose-img:rounded-xl">
            <slot />
          </div>
        </article>
        
        <!-- Sidebar -->
        <aside class="w-full lg:w-80 flex flex-col gap-10">
          <div class="bg-bg-secondary border border-white/10 rounded-2xl p-6">
            <h3 class="text-xl font-bold text-white mb-4">Categories</h3>
            <ul class="space-y-3">
              {categories.map(cat => (
                <li>
                  <a href={`/categories/${cat.id}`} class="text-text-secondary hover:text-white transition-colors flex items-center justify-between">
                    {cat.name}
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </a>
                </li>
              ))}
            </ul>
          </div>
          
          <div>
            <h3 class="text-xl font-bold text-white mb-4">Featured Prompts</h3>
            <div class="flex flex-col gap-4">
              {trendingPrompts.map(prompt => (
                <PromptCard prompt={prompt} />
              ))}
            </div>
          </div>
        </aside>
        
      </div>
    </div>
  </main>
  
  <Footer />
</Layout>

<style is:global>
  .prose h2 {
    margin-top: 2em;
    margin-bottom: 1em;
    font-size: 1.875rem;
    line-height: 1.3333333;
    font-weight: 700;
  }
  .prose p {
    margin-top: 1.25em;
    margin-bottom: 1.25em;
    color: var(--color-text-secondary);
  }
  .prose strong {
    color: white;
    font-weight: 600;
  }
</style>
