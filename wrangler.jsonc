{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ai-prompting-playbook",
  "compatibility_date": "2026-07-18",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "global_fetch_strictly_public",
    "nodejs_compat"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "dist"
  },
  "kv_namespaces": [
    {
      "binding": "SESSION",
      "id": "803d4c3729a64150a0f6b1f1fcd098e9
"
    }
  ]
}
